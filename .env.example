# WorldTwin API Keys — copy to .env and fill in values
# All sources work without keys except those marked REQUIRED

# NASA (DONKI, NeoWs, Mars Photos, EPIC)
NASA_API_KEY=

# NASA Earthdata Login bearer token (LAADS/CMR/Harmony/DAAC downloads).
# Generate at https://urs.earthdata.nasa.gov → My Profile → Generate Token.
# NOTE: expires every ~2 months — renew and update.
EARTHDATA_TOKEN=

# Fire detection
FIRMS_KEY=

# Energy
EIA_API_KEY=
ENTSOE_API_KEY=

# Economic
FRED_API_KEY=

# Air quality
OPENAQ_API_KEY=

# Maritime
GFW_TOKEN=
AISSTREAM_KEY=

# Space
SPACE_TRACK_USER=
SPACE_TRACK_PASS=

# Internet monitoring
CLOUDFLARE_RADAR_TOKEN=

# Media
WINDY_KEY=
YOUTUBE_API_KEY=

# AI narrative
GEMINI_API_KEY=

# Gaming (optional)
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=

# Trade (optional — preview tier works without key)
COMTRADE_KEY=

# Conflict data (free, email request)
UCDP_TOKEN=
